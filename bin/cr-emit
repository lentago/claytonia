#!/usr/bin/env bash
# cr-emit <runid>            — push the final job_complete event to Loki (reads .meta).
#                              Builds the event from logs/<runid>.meta (+ .txt for a PR url).
# cr-emit running <runid> [project] [model]
#                            — push a lightweight job_running heartbeat (no .meta needed),
#                              emitted by run-job every ~10s while a job is in flight so the
#                              "Runners underway" dashboard panel has an in-flight signal.
# cr-emit started <runid> [project] [model]
#                            — push a one-shot job_started event at job pickup (no .meta needed),
#                              so the fleet dashboard can draw task-start markers.
# Low-cardinality fields -> Loki stream labels; full event -> the log line.
set -uo pipefail
JOBS_ROOT="${JOBS_ROOT:-/srv/jobs}"
[ -f /opt/claude-runner/etc/runner.env ] && . /opt/claude-runner/etc/runner.env
LOKI_PUSH_URL="${LOKI_PUSH_URL:-http://192.168.139.20:3100/loki/api/v1/push}"

# loki_push <labels-json> <line-json> — POST one stream value to Loki, stamped now.
loki_push() {
  local labels="$1" line="$2" ns payload
  ns="$(date +%s%N)"
  payload="$(jq -cn --argjson s "$labels" --arg line "$line" --arg ts "$ns" \
    '{streams:[{stream:$s, values:[[$ts,$line]]}]}')"
  curl -sf -m 10 -XPOST "$LOKI_PUSH_URL" -H 'Content-Type: application/json' \
    --data-binary "$payload" >/dev/null
}

# Heartbeat mode: emitted repeatedly while a job runs. Keep it cheap — no file reads.
if [ "${1:-}" = running ]; then
  runid="${2:?usage: cr-emit running <runid> [project] [model]}"
  project="${3:-none}"; [ -z "$project" ] && project="none"
  model="${4:-default}"; [ -z "$model" ] && model="default"
  worker="$(hostname)"
  line="$(jq -cn --arg runid "$runid" --arg project "$project" \
    --arg model "$model" --arg worker "$worker" \
    '{event:"job_running", runid:$runid, project:$project, model:$model, worker:$worker}')"
  labels="$(jq -cn --arg project "$project" --arg model "$model" --arg worker "$worker" \
    '{job:"claude_runner", service:"claude_runner", project:$project, model:$model, worker:$worker}')"
  loki_push "$labels" "$line" && exit 0 || { echo "cr-emit: heartbeat push failed" >&2; exit 1; }
fi

# One-shot start marker: emitted once at job pickup. Keep it cheap — no file reads.
if [ "${1:-}" = started ]; then
  runid="${2:?usage: cr-emit started <runid> [project] [model]}"
  project="${3:-none}"; [ -z "$project" ] && project="none"
  model="${4:-default}"; [ -z "$model" ] && model="default"
  worker="$(hostname)"
  line="$(jq -cn --arg runid "$runid" --arg project "$project" \
    --arg model "$model" --arg worker "$worker" \
    '{event:"job_started", runid:$runid, project:$project, model:$model, worker:$worker}')"
  labels="$(jq -cn --arg project "$project" --arg model "$model" --arg worker "$worker" \
    '{job:"claude_runner", service:"claude_runner", project:$project, model:$model, worker:$worker}')"
  loki_push "$labels" "$line" && exit 0 || { echo "cr-emit: started push failed" >&2; exit 1; }
fi

runid="${1:?usage: cr-emit <runid> | cr-emit running <runid> [project] [model] | cr-emit started <runid> [project] [model]}"
meta="$JOBS_ROOT/logs/${runid}.meta"
txt="$JOBS_ROOT/logs/${runid}.txt"
[ -f "$meta" ] || { echo "cr-emit: no meta for $runid" >&2; exit 1; }

declare -A M
while IFS='=' read -r k v; do [ -n "$k" ] && M[$k]="$v"; done < "$meta"
status=$([ "${M[exit]:-1}" = 0 ] && echo success || echo failed)
project="${M[project]:-}"; [ -z "$project" ] && project="none"
worker="$(hostname)"
pr_url=""; [ -f "$txt" ] && pr_url="$(grep -oE 'https://github.com/[^ )]+/pull/[0-9]+' "$txt" | head -1)"

event="$(jq -cn \
  --arg runid "$runid" --arg project "$project" --arg repo "${M[repo]:-}" \
  --arg model "${M[model]:-default}" --arg status "$status" \
  --arg exit "${M[exit]:-}" --arg dur "${M[duration_sec]:-}" \
  --arg cost "${M[cost_usd]:-}" --arg turns "${M[num_turns]:-}" \
  --arg pr "$pr_url" --arg worker "$worker" --arg fin "${M[finished]:-}" \
  '{event:"job_complete", runid:$runid, project:$project, repo:$repo, model:$model,
    status:$status, exit:($exit|tonumber? // null), duration_sec:($dur|tonumber? // null),
    cost_usd:($cost|tonumber? // 0), num_turns:($turns|tonumber? // null),
    pr_url:$pr, worker:$worker, finished:$fin}')"

labels="$(jq -cn --arg project "$project" --arg status "$status" \
  --arg model "${M[model]:-default}" --arg worker "$worker" \
  '{job:"claude_runner", service:"claude_runner", project:$project,
    status:$status, model:$model, worker:$worker}')"

loki_push "$labels" "$event" && exit 0 || { echo "cr-emit: push failed" >&2; exit 1; }
